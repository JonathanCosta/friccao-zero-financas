# ============================================================
# Financeiro PWA — Variáveis de Ambiente
# Copie este arquivo como .env e ajuste conforme necessário
# ============================================================
# O Vite só expõe ao frontend variáveis com prefixo VITE_
# Demais variáveis são lidas por scripts (test-e2e.mjs, test-sync.sh)
# ============================================================

# --- Frontend (Vite) ---

# URL do Google Apps Script (obrigatório em produção)
# Em DEV o Vite faz proxy para http://localhost:3100 (mock GAS)
# VITE_GAS_URL=

# Se "true", Vite escuta em 0.0.0.0 (acessível da rede local)
# Útil para testar do celular na mesma rede
# Padrão: 127.0.0.1 (apenas localhost)
VITE_ALLOW_EXTERNAL_HOST=false

# --- Testes E2E (scripts/test-e2e.mjs) ---

# Chave de instalação usada nos testes
# Padrão: teste123
# CHAVE_TESTE=

# Se "1", ativa sandbox do Chrome Puppeteer
# Deixe vazio (default) para usar --no-sandbox
# PUPPETEER_SANDBOX=

# --- Script de teste de sincronização (scripts/test-sync.sh) ---

# URL do Google Apps Script (obrigatório para test-sync.sh)
# GAS_URL=

# Chave secreta para autenticação no GAS
# Padrão: MINHA_CHAVE_SECRETA
# CHAVE=
